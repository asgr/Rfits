PKG_CPPFLAGS = -Icfitsio
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = cfitsio/.libs/libcfitsio.a $(SHLIB_OPENMP_CXXFLAGS) -lz

# Suppress upstream cfitsio warnings that we cannot fix
CFITSIO_NOWARN = -Wno-unused-variable -Wno-unused-but-set-variable \
                 -Wno-unused-function -Wno-unused-value

.PHONY: all cfitsio clean shlib-clean

all: $(SHLIB)
$(SHLIB): cfitsio

cfitsio:
	(cd cfitsio && $(MAKE) CFLAGS="$(CFLAGS) $(CFITSIO_NOWARN)" libcfitsio.la)

shlib-clean: clean

clean:
	(cd cfitsio; $(MAKE) clean)

OBJECTS = RcppExports.o Rfits.o
